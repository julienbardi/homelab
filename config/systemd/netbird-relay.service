[Unit]
Description=NetBird Relay Service
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/julie/src/homelab
ExecStart=/usr/bin/docker compose -f config/netbird/docker-compose.netbird.yaml up -d relay
ExecStop=/usr/bin/docker compose -f config/netbird/docker-compose.netbird.yaml stop relay
ExecReload=/usr/bin/docker compose -f config/netbird/docker-compose.netbird.yaml restart relay

[Install]
WantedBy=multi-user.target
