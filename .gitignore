# ============================================================
# Homelab Project .gitignore
# ============================================================
# RULES:
#   1. Never commit secrets or environment files.
#   2. Only commit source templates, not generated configs.
#   3. This repo is designed to live in ~/src/homelab.
#   4. Identities and massive data live on /volume1/ (Physical Firewall).
# ============================================================

# === Logs, OS & IDE Junk ===
*.log
*.tmp
*.bak
*.swp
*.pid
*~
.nfs*
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.idea/
*.iml

# === FreeFileSync Databases ===
*.ffs_db
*.ffs_tmp
*.ffs_lock

# === Build State & Local Tooling ===
.stamps/
.tools/
.cache/
.state/
/build/
/dist/
*.o
*.a
*.so
*.exe

# === Go Toolchain ===
/tmp/age-build/
go.work
go.work.sum

# === Secrets & Environment (The "No-Go" Zone) ===
secrets.tmp.*
*.tmp.*
*.tmp
/tmp/
/tmp/*

.env
*.env
secrets/
/**/secrets/
config/*.generated
*.bak.conf

# PHYSICAL FIREWALL: The patterns below reference paths that live
# OUTSIDE this git repository on the NAS storage pool. They are
# included here as a safety measure in case of cross-mounting.
/volume1/homelab/secrets/
/volume1/homelab/wireguard/

# === SOPS / Encryption Safety ===
# Prevent accidentally committing decrypted buffers
*.decrypted.*
*.tmp.json
*.tmp.yaml

# === Infrastructure & Deployment State ===
terraform.tfstate*
.terraform/
*.service.deployed
*.service.d/

# === Component Specific: Router (ASUSWRT-Merlin) ===
router/archive/
router/addons/
router/cron/
router/wireguard/
router/openvpn/
router/backup/
router/*.log
router/*.tmp
router/*.cache
router/*.state
router/*.pid
router/*.lock
router/*.json
router/*secret*
router/*token*
router/*key*
router/cloudflare_ddns*
router/.cloudflare
router/.ddns_confidential

# === Component Specific: Network & Backup ===
**/wireguard/*.key
**/wireguard/*.conf
**/wireguard/*.runtime
**/wireguard/qr/
**/headscale/*.key
**/headscale/db.sqlite
**/unbound/root.key
caddy/data/
caddy/env
ddns/.ddns_confidential
plan.tsv
alloc.tsv
keys.tsv

# === Future Proofing (Python/Web) ===
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
gen2/site/node_modules/
gen2/site/dist/.cache
.cache

# the KYEID used by sign.sh
# Never commit: contains personal signing workflow, not project tooling.
gpg-keyid

# === GitHub Release Artifacts ===
*.tar.gz
*.tgz
*.zip

# === Local Machine Config ===
mk/config.mk

# === Accidental Files ===
missing
