# Enforce LF line endings for all text files
* text=auto eol=lf

# Treat these as text explicitly
*.sh text eol=lf
*.mk text eol=lf
*.conf text eol=lf
*.example text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files (never touch line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.crt binary
*.key binary
*.zip binary
*.gz binary
*.xz binary
*.tgz binary


