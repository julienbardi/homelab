# 📄 Example configuration for Infomaniak DynDNS
# 🔐 Copy this file and set permission (crucial):
#     cp /jffs/scripts/.ddns.conf.example /jffs/scripts/.ddns_confidential
#     chmod 600 /jffs/scripts/.ddns_confidential
#     chown 0:0 /jffs/scripts/.ddns_confidential
#
# 🌐 Infomaniak setup, see https://faq.infomaniak.com/2376
# 1. Log in to https://manager.infomaniak.com/
# 2. Go to: Products>Web & Domains>Domain
# 3. Select the domain, then Dynamic DNS
# 4. Create an login:
#       Username (login)  → DDNSUSERNAME
#       Password          → DDNSPASSWORD
# 5. These credentials are used ONLY for DynDNS updates.
#
# 🧪 Debugging:
# Set DEBUG=1 to print diagnostic output during updates.
# Default is 0 (silent unless error).

# --- Zone information ---
DNS_TOPDOMAIN_NAME='example.com'
DDNSUSERNAME='your_identifier'
DDNSPASSWORD='your_password'
DEBUG=0
