#!/bin/sh
# Infomaniak DynDNS updater for Asuswrt-Merlin
# https://faq.infomaniak.com/2376

CONF_FILE="/jffs/scripts/.ddns_confidential"
FAQ_URL="https://faq.infomaniak.com/2376"

# Load secrets
if [ -r "$CONF_FILE" ]; then
    . "$CONF_FILE"
else
    echo "⚠️  Missing configuration file: $CONF_FILE"
    /sbin/ddns_custom_updated 0
    exit 1
fi

update_ip() {
    BASE_URL="https://infomaniak.com/nic/update"
    AUTH="-u ${DDNSUSERNAME}:${DDNSPASSWORD}"

    IPV4=$(curl -4 -s --fail https://icanhazip.com | tr -d '\n')
    IPV6=$(curl -6 -s --fail https://icanhazip.com | tr -d '\n')

    status4=$(curl -s $AUTH "${BASE_URL}?hostname=${DNS_TOPDOMAIN_NAME}&myip=${IPV4}" | cut -d' ' -f1)
    status6=$(curl -s $AUTH "${BASE_URL}?hostname=${DNS_TOPDOMAIN_NAME}&myip=${IPV6}" | cut -d' ' -f1)

    if { [ "$status4" = "good" ] || [ "$status4" = "nochg" ]; } &&
       { [ "$status6" = "good" ] || [ "$status6" = "nochg" ]; }; then
		echo "✅ DynDNS update successful for ${DNS_TOPDOMAIN_NAME}: IPv4=$IPV4 ($status4) | IPv6=$IPV6 ($status6)"
        /sbin/ddns_custom_updated 1
    else
		echo "❌ DynDNS update failed for ${DNS_TOPDOMAIN_NAME}: IPv4=$IPV4 ($status4) | IPv6=$IPV6 ($status6)"
        /sbin/ddns_custom_updated 0
		exit 1
    fi
}

update_ip
