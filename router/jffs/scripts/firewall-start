#!/bin/sh
# Managed by git: repo/jffs/scripts/firewall-start
# DO NOT EDIT ON ROUTER
#
# Enforces router-side network invariants:
#   - Policy routing exception for router-originated LAN traffic
#   - IPv4/IPv6 firewall allowances for NAS services
#   - WireGuard forwarding and per-client policy (router- and NAS-terminated)
#
# All rules are idempotent and self-healing.
# Optional services (e.g. Tailscale, Skynet) are restarted last and best-effort.
#
# Added on 2026-01-03 by julie

set -e

IP_ENTWARE="/opt/sbin/ip"

NAS4="10.89.12.4"
NAS6="fd89:7a3b:42c0::4"

PLAN="/jffs/scripts/wireguard/plan.tsv"

log_fw() {
    echo "[fw] $*" >&2
}

###############################################################################
# NAT + FORWARDING FOR NAS-TERMINATED WIREGUARD
###############################################################################

# DNAT: WAN → NAS for WireGuard ports
if ! iptables -t nat -C PREROUTING -i eth0 -p udp --dport 51420:51435 \
        -j DNAT --to-destination "$NAS4" 2>/dev/null; then
    iptables -t nat -A PREROUTING -i eth0 -p udp --dport 51420:51435 \
        -j DNAT --to-destination "$NAS4"
fi

# Allow inbound WG handshake forwarding
if ! iptables -C FORWARD -p udp -d "$NAS4" --dport 51420:51435 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
    iptables -I FORWARD -p udp -d "$NAS4" --dport 51420:51435 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
fi

if ! iptables -C FORWARD -p udp -s "$NAS4" --sport 51420:51435 \
        -m conntrack --ctstate ESTABLISHED -j ACCEPT 2>/dev/null; then
    iptables -I FORWARD -p udp -s "$NAS4" --sport 51420:51435 \
        -m conntrack --ctstate ESTABLISHED -j ACCEPT
fi

###############################################################################
# ROUTER-TERMINATED WIREGUARD (wgs1)
###############################################################################

iptables -N WGSF 2>/dev/null || true

if ! iptables -C WGSF -o br0 -j ACCEPT 2>/dev/null; then
    iptables -A WGSF -o br0 -j ACCEPT
fi

if ! iptables -C WGSF -i br0 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT 2>/dev/null; then
    iptables -A WGSF -i br0 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
fi

while iptables -C FORWARD -i wgs1 -j WGSF 2>/dev/null; do
    iptables -D FORWARD -i wgs1 -j WGSF
done
iptables -I FORWARD 1 -i wgs1 -j WGSF

###############################################################################
# PER-CLIENT WIREGUARD POLICY (NAS-TERMINATED) FROM plan.tsv
###############################################################################

if [ -f "$PLAN" ]; then
    LAN_V4="$(ip -4 addr show dev br0 2>/dev/null | awk '/inet /{print $2; exit}')"
    LAN_V6="$(ip -6 addr show dev br0 2>/dev/null | awk '/inet6 fd/{print $2; exit}')"
    WAN_IF="$(ip route show default 2>/dev/null | awk 'NR==1{print $5}')"

    log_fw "LAN_V4=${LAN_V4:-none} LAN_V6=${LAN_V6:-none} WAN_IF=${WAN_IF:-none}"

    iptables -t filter -N WG_FWD 2>/dev/null || iptables -t filter -F WG_FWD
    ip6tables -t filter -N WG_FWD6 2>/dev/null || ip6tables -t filter -F WG_FWD6
    iptables -t nat    -N WG_NAT 2>/dev/null || iptables -t nat    -F WG_NAT

    iptables  -C FORWARD     -j WG_FWD  2>/dev/null || iptables  -A FORWARD     -j WG_FWD
    ip6tables -C FORWARD     -j WG_FWD6 2>/dev/null || ip6tables -A FORWARD     -j WG_FWD6
    iptables  -t nat -C POSTROUTING -j WG_NAT 2>/dev/null || \
        iptables -t nat -A POSTROUTING -j WG_NAT

    busybox awk -F'\t' '
        /^#/ { next }
        NR==1 && $1=="node" { next }
        NF>=9 { print }
    ' "$PLAN" | while IFS="$(printf '\t')" read -r \
        node iface profile tunnel_mode lan_access egress_v4 egress_v6 \
        client_addr_v4 client_addr_v6 client_allowed_ips_v4 client_allowed_ips_v6 \
        server_addr4 server_addr6 server_allowed_ips_v4 server_allowed_ips_v6 \
        dns endpoint listen_port host_kind
    do
        lan_access="${lan_access:-0}"
        egress_v4="${egress_v4:-0}"
        egress_v6="${egress_v6:-0}"

        [ -z "$client_addr_v4" ] && [ -z "$client_addr_v6" ] && continue

        log_fw "client=${node} iface=${iface} lan=${lan_access} ev4=${egress_v4} ev6=${egress_v6}"

        if [ -n "$LAN_V4" ] && [ -n "$client_addr_v4" ]; then
            if [ "$lan_access" -eq 1 ]; then
                iptables -A WG_FWD -s "$client_addr_v4" -d "$LAN_V4" -j ACCEPT
            else
                iptables -A WG_FWD -s "$client_addr_v4" -d "$LAN_V4" -j DROP
            fi
        fi

        if [ -n "$LAN_V6" ] && [ -n "$client_addr_v6" ]; then
            if [ "$lan_access" -eq 1 ]; then
                ip6tables -A WG_FWD6 -s "$client_addr_v6" -d "$LAN_V6" -j ACCEPT
            else
                ip6tables -A WG_FWD6 -s "$client_addr_v6" -d "$LAN_V6" -j DROP
            fi
        fi

        if [ -n "$WAN_IF" ] && [ -n "$client_addr_v4" ]; then
            if [ "$egress_v4" -eq 1 ]; then
                iptables -A WG_FWD -s "$client_addr_v4" -o "$WAN_IF" -j ACCEPT
                iptables -t nat -A WG_NAT -s "$client_addr_v4" -o "$WAN_IF" -j MASQUERADE
            else
                iptables -A WG_FWD -s "$client_addr_v4" -o "$WAN_IF" -j DROP
            fi
        fi

        if [ -n "$WAN_IF" ] && [ -n "$client_addr_v6" ]; then
            if [ "$egress_v6" -eq 1 ]; then
                ip6tables -A WG_FWD6 -s "$client_addr_v6" -o "$WAN_IF" -j ACCEPT
            else
                ip6tables -A WG_FWD6 -s "$client_addr_v6" -o "$WAN_IF" -j DROP
            fi
        fi
    done
else
    log_fw "plan.tsv missing at $PLAN — skipping per-client WG policy"
fi

###############################################################################
# ROUTER HTTPS INGRESS
###############################################################################

if ! iptables -C INPUT -i eth0 -p tcp --dport 443 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
    iptables -I INPUT -i eth0 -p tcp --dport 443 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
fi

if command -v ip6tables >/dev/null 2>&1; then
    if ! ip6tables -C INPUT -i eth0 -p tcp --dport 443 \
            -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
        ip6tables -I INPUT -i eth0 -p tcp --dport 443 \
            -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
    fi
fi

###############################################################################
# POLICY ROUTING EXCEPTION FOR ROUTER-ORIGINATED LAN TRAFFIC
###############################################################################

if [ -x "$IP_ENTWARE" ]; then
    LAN_TABLE="$($IP_ENTWARE route show table all | awk '
        /10\.89\.12\.0\/24/ && /dev br0/ && /table/ {
            for (i=1;i<=NF;i++) if ($i=="table") {print $(i+1); exit}
        }
    ')"

    if [ -n "$LAN_TABLE" ]; then
        if ! $IP_ENTWARE rule show | grep -q "^5206:.*from 10\.89\.12\.1 .*lookup $LAN_TABLE"; then
            $IP_ENTWARE rule del priority 5206 2>/dev/null
            $IP_ENTWARE rule add priority 5206 from 10.89.12.1 lookup "$LAN_TABLE"
        fi
    fi
fi

###############################################################################
# NAS SERVICE ALLOWANCES
###############################################################################

if ! iptables -C FORWARD -p tcp -d "$NAS4" --dport 443 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
    iptables -I FORWARD -p tcp -d "$NAS4" --dport 443 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
fi

if ! iptables -C FORWARD -p tcp -d "$NAS4" --dport 2222 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
    iptables -I FORWARD -p tcp -d "$NAS4" --dport 2222 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
fi

if ! iptables -C FORWARD -p udp -d "$NAS4" --dport 3478 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
    iptables -I FORWARD -p udp -d "$NAS4" --dport 3478 \
        -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
fi

if command -v ip6tables >/dev/null 2>&1; then
    if ! ip6tables -C FORWARD -p tcp -d "$NAS6" --dport 443 \
            -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT 2>/dev/null; then
        ip6tables -I FORWARD -p tcp -d "$NAS6" --dport 443 \
            -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
    fi
fi

###############################################################################
# ROUTER-TERMINATED WG ROUTE (wgs1)
###############################################################################

ip route replace 10.89.101.0/24 dev wgs1 || true

###############################################################################
# OPTIONAL SERVICES
###############################################################################

if [ -x /opt/bin/tailscale ]; then
    tailscale down >/dev/null 2>&1 || :
    tailscale up   >/dev/null 2>&1 || :
fi

###############################################################################
# FIREWALL AUDIT
###############################################################################

DUP4="$(iptables -S FORWARD | sort | uniq -c | awk '$1 > 1')"
if command -v ip6tables >/dev/null 2>&1; then
    DUP6="$(ip6tables -S FORWARD | sort | uniq -c | awk '$1 > 1')"
else
    DUP6=""
fi

if [ -n "$DUP4" ] || [ -n "$DUP6" ]; then
    echo "❌ Firewall invariant violated: duplicated FORWARD rules detected"
    [ -n "$DUP4" ] && echo "⚠️  IPv4 duplicates:" && echo "$DUP4"
    [ -n "$DUP6" ] && echo "⚠️  IPv6 duplicates:" && echo "$DUP6"
fi

###############################################################################
# SKYNET (DISABLED BY DEFAULT)
###############################################################################

# To enable Skynet, uncomment this block:
#
# if [ -x /jffs/scripts/firewall ] && [ ! -f /tmp/skynet.lock ]; then
#     echo "🛡️  Starting Skynet (best-effort)"
#     sh /jffs/scripts/firewall start skynetloc=/tmp/mnt/sda/skynet || \
#         echo "⚠️  Skynet failed — continuing without it"
# fi

###############################################################################
# BRIDGE STABILIZATION
###############################################################################

sleep 10

if ip link show br0 >/dev/null 2>&1; then
    echo "🔧 Stabilizing LAN bridge (br0)"
    ip link set br0 down
    sleep 1
    ip link set br0 up
fi
