#!/bin/sh
# Managed by git: router/jffs/scripts/firewall-start
# DO NOT EDIT ON ROUTER
#
# Baseline firewall invariants:
#   - Trust LAN (br0)
#   - Preserve established/related flows
#   - Drop unsolicited WAN → router traffic (last-resort)
#
# This script must be safe to run at any time.

set -e

log() { echo "[fw-baseline] $*" >&2; }

# Detect LAN bridge
if ! ip link show br0 >/dev/null 2>&1; then
    log "br0 not present; skipping baseline firewall"
    exit 0
fi

# Accept established/related traffic
iptables -C INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || \
iptables -I INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# Accept LAN → router
iptables -C INPUT -i br0 -j ACCEPT 2>/dev/null || \
iptables -I INPUT -i br0 -j ACCEPT

# Accept loopback
iptables -C INPUT -i lo -j ACCEPT 2>/dev/null || \
iptables -I INPUT -i lo -j ACCEPT

# Last-resort drop for non-LAN traffic to router
iptables -C INPUT ! -i br0 -j DROP 2>/dev/null || \
iptables -A INPUT ! -i br0 -j DROP

log "baseline firewall invariants enforced"
