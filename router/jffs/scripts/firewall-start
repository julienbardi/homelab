#!/bin/sh
# Managed by git: router/jffs/scripts/firewall-start
# DO NOT EDIT ON ROUTER

set -e

log() { echo "[fw-baseline] $*"; }

# Detect LAN bridge
if ! ip link show br0 >/dev/null 2>&1; then
    log "br0 not present; skipping baseline firewall"
    exit 0
fi

# ------------------------------------------------------------
# 1. BASELINE IPV4 FIREWALL INVARIANTS
# ------------------------------------------------------------

# 1. Accept established/related traffic
iptables -C INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || \
iptables -I INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# 2. Accept LAN → router
iptables -C INPUT -i br0 -j ACCEPT 2>/dev/null || \
iptables -I INPUT -i br0 -j ACCEPT

# 3. Accept loopback
iptables -C INPUT -i lo -j ACCEPT 2>/dev/null || \
iptables -I INPUT -i lo -j ACCEPT

# 4. Last-resort drop for non-LAN traffic to router (WAN protection)
iptables -C INPUT ! -i br0 -j DROP 2>/dev/null || \
iptables -A INPUT ! -i br0 -j DROP

log "baseline firewall invariants enforced"

# ------------------------------------------------------------
# 2. DYNAMIC WIREGUARD FIREWALL RULES
# ------------------------------------------------------------

if [ -x /jffs/scripts/wg-firewall.sh ]; then
    log "applying dynamic wg-firewall.sh rules"
    /jffs/scripts/wg-firewall.sh
fi

# ------------------------------------------------------------
# 3. IPV6 WIREGUARD FORWARD SCOPING (WGSF6)
# ------------------------------------------------------------
# This MUST run AFTER wg-firewall.sh because wg-firewall.sh rewrites
# the FORWARD chain and would otherwise delete these rules.

# Skip IPv6 scoping if ip6tables or FORWARD chain is not available
if ! command -v ip6tables >/dev/null 2>&1 || \
   ! ip6tables -S FORWARD >/dev/null 2>&1; then
    # IPv6 not ready in bootstrap context — skip silently
    exit 0
fi

# Ensure WGSF6 chain exists
if ! ip6tables -L WGSF6 >/dev/null 2>&1; then
    log "creating WGSF6 chain"
    ip6tables -N WGSF6
fi

# ------------------------------------------------------------
# Deduplicate existing WGSF6 rules (Merlin re-inserts them)
# ------------------------------------------------------------

# Delete all but one inbound rule
while [ "$(ip6tables -S FORWARD | grep -c ' -i wg+ -j WGSF6')" -gt 1 ]; do
    ip6tables -D FORWARD -i wg+ -j WGSF6 2>/dev/null || true
done

# Delete all but one outbound rule
while [ "$(ip6tables -S FORWARD | grep -c ' -o wg+ -j WGSF6')" -gt 1 ]; do
    ip6tables -D FORWARD -o wg+ -j WGSF6 2>/dev/null || true
done

# Ensure FORWARD -i wg+ -> WGSF6
if ! ip6tables -S FORWARD | grep -q -- "^-A FORWARD -i wg\+ -j WGSF6"; then
    log "adding IPv6 FORWARD -i wg+ -> WGSF6"
    ip6tables -I FORWARD -i wg+ -j WGSF6
fi

# Ensure FORWARD -o wg+ -> WGSF6
if ! ip6tables -S FORWARD | grep -q -- "^-A FORWARD -o wg\+ -j WGSF6"; then
    log "adding IPv6 FORWARD -o wg+ -> WGSF6"
    ip6tables -I FORWARD -o wg+ -j WGSF6
fi

log "IPv6 WireGuard FORWARD scoping enforced"
